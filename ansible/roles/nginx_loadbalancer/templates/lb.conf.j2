# system directivess
user www-data;
worker_processes auto;
pid /run/nginx.pid;
#----


events {
    worker_connections 1024;
}

http {

    upstream app_servers {
        {% for host in groups['role_web-server'] %}
        server {{ host }}:80;
        {% endfor %}
    }

    server {
        listen 80;

        location / {
            proxy_pass http://app_servers;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }
    }
}